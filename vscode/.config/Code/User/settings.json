{
  "editor.wordWrapColumn": 100,
  // "editor.fontFamily": "Iosevka Medium",
  // "editor.fontFamily": "Ubuntu Mono derivative Powerline",
  "editor.fontFamily": "Fira Code Medium",
  "editor.lineNumbers": "off",
  "editor.minimap.enabled": false,
  "editor.tabCompletion": true,
  "keyboard.dispatch": "keyCode",
  "vim.leader": "<space>",
  "vim.useCtrlKeys": true,
  "window.menuBarVisibility": "hidden",
  "window.zoomLevel": 0,
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [";"],
      "after": [":"]
    },
    {
      "before": [":"],
      "after": [";"]
    },
    {
      "before": ["H"],
      "after": ["g", "^"]
    },
    {
      "before": ["L"],
      "after": ["g", "$"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": [";"],
      "after": [":"]
    },
    {
      "before": [":"],
      "after": [";"]
    },
    {
      "before": ["H"],
      "after": ["g", "^"]
    },
    {
      "before": ["L"],
      "after": ["g", "$"]
    }
  ],
  "editor.acceptSuggestionOnEnter": "off",
  "editor.fontLigatures": true,
  "editor.formatOnSave": true,
  "latex-workshop.chktex.enabled": true,
  "prettier.bracketSpacing": false,
  "prettier.semi": false,
  "prettier.singleQuote": true,
  "prettier.trailingComma": "all",
  "vim.useSystemClipboard": true,
  "workbench.activityBar.visible": false,
  "files.associations": {
    "*.ml": "ocaml",
    "*.mli": "ocaml",
    "*.scm": "scheme"
  },
  "extensions.ignoreRecommendations": false,
  "ocaml.lintOnChange": false,
  "ocaml.lintOnSave": true,
  "ocaml.replPath.unix": "utop",
  // "files.autoSave": "afterDelay",
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/_build": true
  },
  "git.autofetch": true,
  "prettier.printWidth": 100,
  "shellcheck.run": "onSave",
  "yaml.format.enable": false,
  "vim.handleKeys": {
    "<C-b>": false,
    "<C-n>": false
  },
  "vim.disableExtension": false,
  "vim.foldfix": false,
  "workbench.colorTheme": "Winter is Coming (Dark Blue - No Italics)",
  "search.smartCase": true,
  "latex-workshop.view.pdf.viewer": "tab",
  "workbench.startupEditor": "newUntitledFile",
  "C_Cpp.clang_format_fallbackStyle": "none",
  "diffEditor.ignoreTrimWhitespace": false,
  "python.pythonPath": "/usr/bin/python2",
  "window.titleBarStyle": "native",
  "C_Cpp.dimInactiveRegions": false,
  "python.formatting.provider": "none",
  "editor.wordWrap": "wordWrapColumn",
  "C_Cpp.updateChannel": "Insiders",
  "C_Cpp.default.cppStandard": "c++14",
  "explorer.confirmDragAndDrop": false,
  "editor.fontSize": 12,
  "workbench.statusBar.visible": false
}
