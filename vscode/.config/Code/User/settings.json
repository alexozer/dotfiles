{
  "editor.wordWrapColumn": 100,
  "editor.fontFamily": "Fira Code Medium",
  "editor.minimap.enabled": false,
  "keyboard.dispatch": "keyCode",
  "vim.leader": "<space>",
  "vim.useCtrlKeys": true,
  "window.menuBarVisibility": "hidden",
  "window.zoomLevel": 0,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.fontLigatures": true,
  "latex-workshop.chktex.enabled": true,
  "prettier.bracketSpacing": false,
  "prettier.semi": false,
  "prettier.singleQuote": true,
  "prettier.trailingComma": "all",
  "vim.useSystemClipboard": true,
  "workbench.activityBar.visible": false,
  "files.associations": {
    "*.ml": "ocaml",
    "*.mli": "ocaml",
    "*.scm": "scheme"
  },
  "extensions.ignoreRecommendations": false,
  "ocaml.lintOnChange": false,
  "ocaml.lintOnSave": true,
  "ocaml.replPath.unix": "utop",
  "files.autoSave": "afterDelay",
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/_build": true
  },
  "git.autofetch": true,
  "prettier.printWidth": 100,
  "shellcheck.run": "onSave",
  "yaml.format.enable": false,
  "vim.handleKeys": {
    "<C-b>": false,
    "<C-n>": false
  },
  "vim.disableExtension": false,
  "vim.foldfix": false,
  "workbench.colorTheme": "Nord",
  "search.smartCase": true,
  "latex-workshop.view.pdf.viewer": "tab",
  "workbench.startupEditor": "newUntitledFile",
  "C_Cpp.clang_format_fallbackStyle": "none",
  "diffEditor.ignoreTrimWhitespace": false,
  "python.pythonPath": "/usr/bin/python3",
  "window.titleBarStyle": "native",
  "C_Cpp.dimInactiveRegions": false,
  "python.formatting.provider": "none",
  "C_Cpp.updateChannel": "Insiders",
  "C_Cpp.default.cppStandard": "c++14",
  "explorer.confirmDragAndDrop": false,
  "editor.fontSize": 11,
  "editor.lineHeight": 16,
  // "workbench.statusBar.visible": false,
  "explorer.confirmDelete": false,
  "update.mode": "manual",
  "vsicons.dontShowNewVersionMessage": true,
  // "workbench.colorCustomizations": {
  //   "editorError.foreground": "#00000000",
  //   "editorWarning.foreground": "#00000000",
  //   "editorInfo.foreground": "#00000000"
  // },
  "errorLens.errorForeground": "#ffffff80",
  "errorLens.warningForeground": "#ffffff80",
  "errorLens.hintForeground": "#ffffff80",
  "errorLens.infoForeground": "#ffffff80",
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        ":"
      ],
      "after": [
        ";"
      ]
    },
    {
      "before": [
        ";"
      ],
      "after": [
        ":"
      ]
    },
    {
      "before": [
        "H"
      ],
      "after": [
        "^"
      ]
    },
    {
      "before": [
        "L"
      ],
      "after": [
        "$"
      ]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": [
        ":"
      ],
      "after": [
        ";"
      ]
    },
    {
      "before": [
        ";"
      ],
      "after": [
        ":"
      ]
    },
    {
      "before": [
        "H"
      ],
      "after": [
        "^"
      ]
    },
    {
      "before": [
        "L"
      ],
      "after": [
        "$"
      ]
    }
  ],
  "gitlens.hovers.currentLine.over": "line",
  "scm.diffDecorationsGutterVisibility": "hover",
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "cmake.cpptools.intelliSenseMode": "gcc-x64",
  "cmake.configureOnOpen": true,
  "prettier.proseWrap": "never",
  "vscode-neovim.neovimPath": "/usr/bin/nvim",
}