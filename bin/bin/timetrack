#!/usr/bin/env bash

dirname=~/doc/Dropbox/notes/timetrack
interval=$((60 * 45))

function previous_entry_day() {
    line=$(tac "$1" | grep -P -m 1 '^# ')
    if [[ -n "$line" ]]; then
        date --date="${line:2}" '+%d'
    fi
}

while sleep "$interval"; do
    read -r status # Replace with zenity
    curr_datetime=$(date)

    mkdir -p "$dirname"
    fname=$(date --date="$curr_datetime" '+%b-%Y.md')
    fname=${fname,,} # Lower case
    pathname=$dirname/$fname
    touch "$pathname"

    prev_day=$(previous_entry_day "$pathname")
    curr_day=$(date --date="$curr_datetime" '+%d')
    date_header=$(date --date="$curr_datetime" '+# %a %d %b %Y')

    if [[ -z "$prev_day" ]]; then
        echo -e "$date_header\n" >> "$pathname"
    elif [[ "$prev_day" != "$curr_day" ]]; then
        echo -e "\n$date_header\n" >> "$pathname"
    fi

    curr_time=$(date --date="$curr_datetime" '+%I:%M %p')
    echo "$curr_time: $status" >> "$pathname"
done
