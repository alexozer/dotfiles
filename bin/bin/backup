#!/usr/bin/env bash

set -uo pipefail
shopt -s dotglob nullglob

backupDirs="code doc pic .dotfiles"
tetherSSID="Alex's iPhone"

doBackup() {
	# Avoid backing up over tethered cell connection
	if [[ "$(iwgetid --raw)" = "$tetherSSID" ]]; then
		echo "Connected to $tetherSSID, not backing up"
		return 1
	fi

	# Push dotfiles
	cd "$HOME"/.dotfiles
	git add .
	git commit -m "Update $(date +%D)"
	git push

	# Record installed packages
	pacman -Qqen > ~/doc/personal/pkgs-native-explicit.txt
	pacman -Qqem > ~/doc/personal/pkgs-foreign-explicit.txt
	pacman -Qqn > ~/doc/personal/pkgs-native-all.txt
	pacman -Qqm > ~/doc/personal/pkgs-foreign-all.txt

	# Backup files
	for dir in $backupDirs; do
		rclone sync "$HOME"/"$dir" box:"$dir" --skip-links
	done
}

fail() {
	email-me "Backup failed!" "$*"
	return 1
}

errors=$(doBackup 2>&1) || fail "$errors"
