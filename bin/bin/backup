#!/bin/bash
set -uo pipefail
#trap 's=$?; echo "$0: Error on line "$LINENO": $BASH_COMMAND"; exit $s' ERR
#IFS=$'\n\t'
shopt -s dotglob nullglob

export SSH_AUTH_SOCK=/run/user/1000/keyring/ssh

backupDirs="code doc pic"
remoteDir="pi:/media/backup/tinfoil"

doBackup() {
	cd "$HOME"/.dotfiles
	git add .
	git commit -m "Update $(date +%D)"
	git push

	for dir in $backupDirs; do
		rclone sync "$HOME"/"$dir" box:"$dir" --skip-links
	done
}

fail() {
	ntfy -b linux -b simplepush send $'Backup failed!\n'"$*"
	return 1
}

errors=$(doBackup 2>&1) || fail "$errors"
