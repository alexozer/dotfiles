#!/usr/bin/env bash

set -euo pipefail
shopt -s dotglob nullglob

backupDirs="code doc pic .dotfiles win vid music .local/share/dolphin-emu"
tetherSSID="Alex's iPhone"

doBackup() {
	set -euo pipefail
	sh sdfasdfasdfasdfasd

	# Avoid backing up over tethered cell connection
	if [[ "$(iwgetid --raw)" = "$tetherSSID" ]]; then
		echo "Connected to $tetherSSID, not backing up"
		return 1
	fi

	# Push dotfiles
	cd "$HOME"/.dotfiles
	git add .
	git commit -m "Update $(date +%D)" || :
	git push

	# Add notes to git repo
	cd "$HOME"/doc/personal/Dropbox/notes
	git add .
	git commit -m "Update $(date +%D)" || :

	# Record installed packages
	pacman -Qqen > ~/doc/personal/arch/pkgs-native-explicit.txt
	pacman -Qqem > ~/doc/personal/arch/pkgs-foreign-explicit.txt
	pacman -Qqn > ~/doc/personal/arch/pkgs-native-all.txt
	pacman -Qqm > ~/doc/personal/arch/pkgs-foreign-all.txt

	# Backup files
	for dir in $backupDirs; do
		rclone sync "$HOME"/"$dir" box:"$dir" --skip-links
	done

	# Upgrade oh-my-zsh, because why not do it here?
	sh ~/.oh-my-zsh/tools/upgrade.sh
}

fail() {
	notify-me "Backup failed!" "$*"
	return 1
}

errors=$(doBackup 2>&1) || fail "$errors"
