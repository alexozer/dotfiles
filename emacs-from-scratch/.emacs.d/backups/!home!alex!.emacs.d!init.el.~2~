;;
;; Iniitialize package management system in a more sane way
;;

(let ((gc-cons-threshold most-positive-fixnum))

  ;; Set repositories
  (require 'package)
  (package-initialize)
  (setq-default
   load-prefer-newer t
   package-enable-at-startup nil)
  (add-to-list 'package-archives '("melpa" . "http://melpa.org/packages/") t)
  (add-to-list 'package-archives '("org" . "http://orgmode.org/elpa/") t)

  ;; Install dependencies
  (unless (package-installed-p 'use-package)
    (package-refresh-contents)
    (package-install 'use-package t))
  (setq-default use-package-always-ensure t)
  (garbage-collect))

;;
;; Editor settings not specific to a package
;;

(setq-default
  use-dialog-box nil
  inhibit-splash-screen t
  visible-bell nil

  vc-follow-symlinks nil ;; Don't warn about my symlinked dotfiles

  indent-tabs-mode nil
  tab-width 2

  backup-by-copying t
  backup-directory-alist '(("." . "~/.emacs.d/backups"))
  auto-save-file-name-transforms `((".*" "~/.emacs.d/backups/" t))
  version-control t
  delete-old-versions t

  ;; Scroll better?
  scroll-conservatively 1000 ;; Only 'jump' when moving this far
  scroll-margin 4 ;; Scroll N lines to screen edge
  scroll-step 1 ;; Keyboard scroll one line at a time
  mouse-wheel-progressive-speed nil ;; Don't accelerate scrolling
  redisplay-dont-pause t ;; Don't pause display on input
  ;; Always redraw immediately when scrolling,
  ;; More responsive and doesn't hang!
  fast-but-imprecise-scrolling nil
  jit-lock-defer-time 0

  custom-file (expand-file-name "custom.el" user-emacs-directory)
)

(menu-bar-mode -1)
(tool-bar-mode -1)
(toggle-scroll-bar -1)
(fset 'yes-or-no-p 'y-or-n-p)
(save-place-mode) ;; Restore cursor position in file on open
(add-hook 'focus-out-hook #'garbage-collect)
(when (file-exists-p custom-file)
  (load custom-file))

;;
;; Package config
;;

(use-package evil
  :init
  (setq evil-want-Y-yank-to-eol t)
  (setq evil-vsplit-window-right t)
  (setq evil-split-window-below t)
  (setq evil-ex-substitute-global t)
  (setq evil-insert-state-message nil)
  (setq evil-visual-state-message nil)

  :config (evil-mode))

(use-package general
  :config

  (general-def 'motion
    ":" 'evil-repeat-find-char
    ";" 'evil-ex
    "j" 'evil-next-visual-line          
    "k" 'evil-previous-visual-line
    "H" 'evil-first-non-blank
    "L" 'evil-end-of-line)

  (general-def 
    :states '(normal visual)
    :prefix " "
    "i" (lambda () (interactive) (find-file (expand-file-name "init.el" user-emacs-directory)))
    )
  )

(use-package spacemacs-common
  :ensure spacemacs-theme
  :config
  (load-theme 'spacemacs-dark t))

(use-package evil-commentary
  :config (evil-commentary-mode))

(use-package org
  :ensure org-plus-contrib
  :hook (org-mode . org-indent-mode)
  :config
  (setq org-log-done 'time))
