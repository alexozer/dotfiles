! xterm Settings
xterm*termName:		xterm-256color
xterm*locale:		true
xterm*metaSendsEscape:	true
xterm*saveLines:	4096
XTerm*cursorBlink: false
xterm*scaleHeight: 1.01
xterm*scrollKey:	true
xterm*jumpScroll:	true

! Xft.dpi: 260
! Xft.autohint: 1
! Xft.lcdfilter:  lcddefault
! Xft.hintstyle:  hintfull
! Xft.hinting: 1
! Xft.antialias: 1
! Xft.rgba: rgb

! Xft.antialias: 1
! Xft.autohint: 1
! Xft.hintstyle: hintslight

! xterm*faceName:			xft:Fira Mono:style=Medium:pixelsize=15:antialias=true:hinting=true:hintstyle=hintslight
xterm*faceName:			xft:Fira Mono:style=Medium:pixelsize=15:antialias=true

! VT Font Menu: Unreadable
xterm*faceSize1: 8
! VT font menu: Tiny
xterm*faceSize2: 10
! VT font menu: Medium
xterm*faceSize3: 12
! VT font menu: Large
xterm*faceSize4: 15
! VT font menu: Huge
xterm*faceSize5: 22

! stuff I am not sure is necessary
xterm*multiScroll:	true
xterm*toolBar:		false
xterm*eightBitInput:	false
xterm*scrollTtyOutput:	false
xterm*scrollBar:	false
xterm*rightScrollBar:	false
xterm*bellIsUrgent:	true
xterm*dynamicColors:	true
xterm*utf8:		2
xterm*VT100.geometry:	80x32

! Remapping ctrl-backspace thanks to https://www.vinc17.net/unix/ctrl-backspace.en.html

xterm*vt100.translations: #override \
    Shift Ctrl <Key> C: copy-selection(CLIPBOARD) \n\
    Shift Ctrl <Key> V: insert-selection(CLIPBOARD) \n\
    Ctrl <Key> +:       larger-vt-font() \n\
    Ctrl <Key> -:       smaller-vt-font() \n\
    Ctrl <Key> 0: set-vt-font(d) \n\
    Ctrl<Key>BackSpace: string("\033[34~")

! Dracula Xresources palette to match kitty Dracula
*.cursorColor: #bbbbbb
*.background: #1e1f28
*.foreground: #f8f8f2
*.color0: #000000
*.color8: #545454
*.color1: #ff5555
*.color9: #ff5454
*.color2: #50fa7b
*.color10: #50fa7b
*.color3: #f0fa8b
*.color11: #f0fa8b
*.color4: #bd92f8
*.color12: #bd92f8
*.color5: #ff78c5
*.color13: #ff78c5
*.color6: #8ae9fc
*.color14: #8ae9fc
*.color7: #bbbbbb
*.color15: #ffffff

