
# bspwm hotkeys

alt + shift + q; {l, s, p, r, x}
	{bspc quit, systemctl suspend, systemctl poweroff, systemctl reboot, i3lock-fancy}

alt + c
	bspc node --close

alt + equal
	bspc node @/ --ratio 0.6180339903912632

alt + minus
	bspc node @/ --equalize

alt + b
	bspc node @/ --balance

alt + {n,i}
	bspc desktop {next,prev} -f

alt + {1-9,0}
	bspc desktop ^{1-9,0} -f

alt + ctrl + shift + {n,i}
	bspc desktop --bubble {next,prev} --focus

alt + {_,shift + }f
	bspc node --state {\~floating,\~pseudo_tiled}

alt + y
	bspc node --to-node last.!automatic

alt + m
	bspc desktop --layout next

alt + {_,shift +} {h,j,k,l}
	bspc node {--focus,--swap} {west,south,north,east}

alt + {_,shift + }Tab
	bspc node --focus {next.local,prev.local}

alt + {_,shift + }r
	bspc node @/ --rotate {270,90}

alt + ctrl + {h,j,k,l}
	bspc node --presel-dir \~{west,south,north,east}

alt + shift + {n,i}
	bspc node --to-desktop {next,prev} --focus

#
# wm-independent hotkeys
#

alt + Escape
	rofi -show drun

alt + Return
	gnome-terminal

alt + w
	chromium

alt + e
	thunar

alt + s
	xfce4-screenshooter

# for laptop
{XF86AudioRaiseVolume, XF86AudioLowerVolume, XF86AudioMute}
	amixer set Master {2%+, 2%-, toggle}

{XF86AudioPrev, XF86AudioPlay, XF86AudioNext}
	playerctl {previous, play-pause, next}

# make sxhkd reload its configuration files:
alt + shift + Escape
	pkill -USR1 -x sxhkd

alt + t
	gnome-terminal -- htop

alt + {comma,period}
	gnome-terminal -e 'ssh {artemis,apollo}'

alt + shift + Return
	gnome-terminal -e 'ssh auv'

alt + shift + {comma,period}
	exo-open http://192.168.0.{93,91}:5000

alt + shift + p
	ntfy -b phone send "$(xsel -b)"

# Utilities to replace panel

alt + o
	bspc rule --add Gnome-terminal --one-shot state=floating &&\
	gnome-terminal -x /usr/bin/bash -ic 'rg --color never --files | fzf --reverse | xargs echo -n | xargs -0 exo-open'
