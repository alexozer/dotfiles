#
# bspwm keybindings
#

super + shift + q; {l, s, p, r}
	{bspc quit, systemctl suspend, systemctl poweroff, systemctl reboot}

super + c
	bspc node --close

super + equal
	bspc node @/ --ratio 0.6180339903912632

super + minus
	bspc node @/ --equalize

super + b
	bspc node @/ --balance

super + {n,i}
	bspc desktop {next,prev} --focus

# Toggle between previous desktop if target desktop number is current desktop
super + {1-9,0}
	target={1-9,10}; \
	if [ "$(bspc query -D -d focused)" != "$(bspc query -D -d ^$target)" ]; then; \
		bspc desktop ^$target --focus; \
	else; \
		bspc desktop last --focus; \
	fi

super + shift + {1-9,0}
	bspc node --to-desktop ^{1-9,10} --focus

super + shift + {n,i}
	bspc node --to-desktop {next,prev} --focus

super + ctrl + shift + {1-9,0}
	bspc desktop --swap ^{1-9,10} --focus; \
	bspc monitor -d 1 2 3 4 5 6 7 8 9 0

super + ctrl + shift + {n,i}
	bspc desktop --swap {next,prev} --focus; \
	bspc monitor -d 1 2 3 4 5 6 7 8 9 0

super + {_,shift + }f
	bspc node --state {\~floating,\~pseudo_tiled}

super + y
	bspc node --to-node last.!automatic

super + m
	bspc desktop --layout next

super + {_,shift +} {h,j,k,l}
	bspc node {--focus,--swap} {west,south,north,east}

super + {_,shift + }Tab
	bspc node --focus {next.local,prev.local}

super + {_,shift + }r
	bspc node @/ --rotate {270,90}

super + ctrl + {h,j,k,l}
	bspc node --presel-dir \~{west,south,north,east}

#
# wm-independent keybindings
#

super + Escape
	xfce4-popup-whiskermenu

super + Return
	gnome-terminal

super + w
	chromium

super + shift + w
	chromium --incognito

super + v
	code -n

super + e
	thunar

super + {s,S}; {r,f,w}
	xfce4-screenshooter --{imgur,clipboard} --{region,fullscreen,window}

# for laptop
{XF86AudioRaiseVolume, XF86AudioLowerVolume, XF86AudioMute}
	pamixer {--increase 2,--decrease 2,--toggle-mute}

super + XF86AudioMute
	pamixer --mute

{XF86AudioPrev, XF86AudioPlay, XF86AudioNext}
	playerctl {previous, play-pause, next}

XF86LaunchB
	betterlockscreen -l

# make sxhkd reload its configuration files:
super + shift + Escape
	pkill -USR1 -x sxhkd

super + t
	gnome-terminal -- htop

super + {comma,period}
	gnome-terminal -e 'ssh {artemis,apollo}'

super + shift + Return
	gnome-terminal -e 'ssh auv'

super + shift + {comma,period}
	exo-open http://192.168.0.{93,91}:5000

super + ctrl + p
	ntfy -b phone send "$(xsel -b)"

super + o
	gnome-terminal-popup bookmarks 160x24

super + O
	gnome-terminal-popup 'rg --color never --files |\
	fzf-dmenu | xargs echo -n | xargs -0 exo-open'

super + u
	spotify --force-device-scale-factor=1.4

super + p
	gnome-terminal-popup "CM_LAUNCHER='fzf-dmenu' clipmenu -i"

# Password manager
super + shift + p
	gnome-terminal-popup "gopass ls --flat |\
	fzf-dmenu | tee >(xargs --no-run-if-empty gopass show -f |\
	head -n 1 | tr -d '\n' |\
	xdotool type --delay 0 --clearmodifiers --file -)"
