#
# bspwm keybindings
#

alt + shift + q; {l, s, p, r}
	{bspc quit, systemctl suspend, systemctl poweroff, systemctl reboot}

alt + c
	bspc node --close

alt + equal
	bspc node @/ --ratio 0.6180339903912632

alt + minus
	bspc node @/ --equalize

alt + b
	bspc node @/ --balance

alt + {n,i}
	bspc desktop {next,prev} --focus

# Unfortunately the multiple binding thing doesn't work in this case

alt + 1
	if [ "$(bspc query -D -d focused)" != "$(bspc query -D -d ^1)" ]; then bspc desktop ^1 --focus; else bspc desktop last --focus; fi

alt + ctrl + shift + {n,i}
	bspc desktop --bubble {next,prev} --focus

alt + ctrl + shift + {0-9}
	bspc desktop --swap ^{0-9} --focus

alt + {_,shift + }f
	bspc node --state {\~floating,\~pseudo_tiled}

alt + y
	bspc node --to-node last.!automatic

alt + m
	bspc desktop --layout next

alt + {_,shift +} {h,j,k,l}
	bspc node {--focus,--swap} {west,south,north,east}

alt + {_,shift + }Tab
	bspc node --focus {next.local,prev.local}

alt + {_,shift + }r
	bspc node @/ --rotate {270,90}

alt + ctrl + {h,j,k,l}
	bspc node --presel-dir \~{west,south,north,east}

alt + shift + {n,i}
	bspc node --to-desktop {next,prev} --focus

alt + shift + {0-9}
	bspc node --to-desktop ^{0-9} --focus

#
# wm-independent keybindings
#

alt + Escape
	xfce4-popup-whiskermenu

alt + Return
	gnome-terminal

alt + w
	chromium

alt + shift + w
	chromium --incognito

alt + v
	code -n

alt + e
	thunar

alt + s; {r,f,w}
	xfce4-screenshooter --{region,fullscreen,window} --imgur

# for laptop
{XF86AudioRaiseVolume, XF86AudioLowerVolume, XF86AudioMute}
	pamixer {--increase 2,--decrease 2,--toggle-mute}

alt + XF86AudioMute
	pamixer --mute

{XF86AudioPrev, XF86AudioPlay, XF86AudioNext}
	playerctl {previous, play-pause, next}

XF86LaunchB
	betterlockscreen -l

# make sxhkd reload its configuration files:
alt + shift + Escape
	pkill -USR1 -x sxhkd

alt + t
	gnome-terminal -- htop

alt + {comma,period}
	gnome-terminal -e 'ssh {artemis,apollo}'

alt + shift + Return
	gnome-terminal -e 'ssh auv'

alt + shift + {comma,period}
	exo-open http://192.168.0.{93,91}:5000

alt + ctrl + p
	ntfy -b phone send "$(xsel -b)"

alt + o
	bspc rule --add Gnome-terminal --one-shot state=floating &&\
	gnome-terminal -x /usr/bin/bash -ic 'rg --color never --files | fzf --reverse | xargs echo -n | xargs -0 exo-open'

alt + u
	dex ~/.local/share/applications/spotify.desktop

# alt + p
# 	CM_LAUNCHER='rofi-dmenu' clipmenu -i

alt + shift + p
	gopass ls --flat | rofi-dmenu | xargs --no-run-if-empty gopass show -f | head -n 1 | tr -d '\n' | xdotool type --delay 0 --clearmodifiers --file -
