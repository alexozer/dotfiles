#
# bspwm keybindings
#

super + shift + q; {l, s, p, r}
	{bspc quit, systemctl suspend, systemctl poweroff, systemctl reboot}

super + c
	bspc node --close

super + equal
	bspc node @/ --ratio 0.6180339903912632

super + minus
	bspc node @/ --equalize

super + b
	bspc node @/ --balance

super + {n,i}
	bspc desktop primary:focused#{next,prev}.local --focus

# Toggle between previous desktop if target desktop number is current desktop
super + {1-9,0}
	target={1-9,10}; \
	if [ "$(bspc query -D -d focused)" != "$(bspc query -D -d ^$target)" ]; then; \
		bspc desktop ^$target --focus; \
	else; \
		bspc desktop last --focus; \
	fi

super + shift + {1-9,0}
	bspc node --to-desktop ^{1-9,10} --focus

super + shift + {n,i}
	bspc node --to-desktop primary:focused#{next,prev}.local --focus

super + ctrl + shift + {1-9,0}
	bspc desktop --swap ^{1-9,10} --focus; \
	bspc monitor -d 1 2 3 4 5 6 7 8 9 0

super + ctrl + shift + {n,i}
	bspc desktop --swap primary:focused#{next,prev}.local --focus; \
	bspc monitor -d 1 2 3 4 5 6 7 8 9 0

super + {_,shift + }f
	bspc node --state {\~floating,\~pseudo_tiled}

super + y
	bspc node --to-node last.!automatic

super + m
	bspc desktop --layout next

super + {h,j,k,l}
	bspc node --focus {west,south,north,east}

super + shift + {h,j,k,l}
	bspc node --swap {west,south,north,east} --focus

super + {_,shift + }Tab
	bspc node --focus {next.local,prev.local}

super + {_,shift + }r
	bspc node @/ --rotate {270,90}

super + ctrl + {h,j,k,l}
	bspc node --presel-dir \~{west,south,north,east}

super + {comma,period}
	bspc monitor --focus {west,east}

super + shift + {comma,period}
	bspc node --to-monitor {west,east} --follow

#
# wm-independent keybindings
#

super + space
	rofi -show drun -show-icons

super + Return
	gnome-terminal

super + w
	firefox-developer-edition

super + shift + w
	firefox-developer-edition --private-window

super + v; {c, p, v, j, g}
	{clion, pycharm, code -n, intellij, goland}

super + e
	thunar

super + {s, S}; {r,f,w}
	maim {,-d 2} {-s,-i root,-i $(xdotool getactivewindow)} /tmp/screenshot.png && ;\
	imgur.sh /tmp/screenshot.png | head -n1 | ;\
	tee >(xargs notify-send 'Screenshot captured') >(xsel -ib)

# for laptop
{XF86AudioRaiseVolume, XF86AudioLowerVolume, XF86AudioMute}
	pamixer {--increase 2,--decrease 2,--toggle-mute}

super + XF86AudioMute
	pamixer --mute

{XF86AudioPrev, XF86AudioPlay, XF86AudioNext}
	playerctl {previous, play-pause, next}

XF86LaunchB
	betterlockscreen -l

# make sxhkd reload its configuration files:
super + shift + Escape
	pkill -USR1 -x sxhkd

super + t
	gnome-terminal -- htop

super + ctrl + p
	ntfy -b phone send "$(xsel -b)"

super + o
	gnome-terminal-popup browser-bookmarks

super + O
	gnome-terminal-popup 'rg --color never --files |\
	fzf-dmenu | xargs echo -n | xargs -0 exo-open'

super + u
	spotify --force-device-scale-factor=1.4

super + p
	gnome-terminal-popup "CM_LAUNCHER='fzf-dmenu' clipmenu -i"

# Password manager
super + shift + p
	gnome-terminal-popup gopass-ui

# Wait a second before typing password so form can refocus
super + shift + ctrl + p
	gnome-terminal-popup "gopass-ui 1"

super + x
	gnome-terminal-popup fkill 160x24

super + {bracketleft,bracketright}
	xrandr --output primary --mode {1280x800,2560x1600}

super + shift + b
	gnome-terminal-popup 'nvim ~/doc/personal/bookmarks' 160x24

super + {Down,Up}
	xbacklight -{dec,inc} 1
