#
# Chorded keybindings that i3 can't support natively
#

super + shift x; {l, s, p, r}
    {i3-msg exit, systemctl suspend, systemctl poweroff, systemctl reboot}

super + g; w
    firefox-developer-edition

super + g, shift + w
    firefox-developer-edition --private-window

super + g; e
    thunar

super + g; u
    spotify --force-device-scale-factor=1.2

super + g; s
    maim -s ~/screenshot.png

super + g; g
    ghidra

super + g;  c
    clion

super + g; i
    intellij

super + g; p
    pycharm

super + g; d
    discord

super + g; f
    dolphin-emu

super + g; F
    dme

super + g; m
    pavucontrol

super + g; b
    gksudo baobab

# vim:shiftwidth=4
