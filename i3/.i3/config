# General i3 settings

font pango:noto sans 11

set $up k
set $down j
set $left h
set $right l

floating_modifier Mod4
focus_follows_mouse no
workspace "ext" output HDMI2

# i3 bindings

bindsym Mod4+$left focus left
bindsym Mod4+$down focus down
bindsym Mod4+$up focus up
bindsym Mod4+$right focus right

bindsym Mod4+Shift+$left move left
bindsym Mod4+Shift+$down move down
bindsym Mod4+Shift+$up move up
bindsym Mod4+Shift+$right move right

bindsym Mod4+semicolon split h
bindsym Mod4+v split v

bindsym Mod4+m fullscreen toggle
bindsym Mod4+f floating toggle
bindsym Mod4+Shift+f focus mode_toggle

bindsym Mod4+r layout toggle split
bindsym Mod4+y layout stacking
bindsym Mod4+b layout tabbed

bindsym Mod4+a focus parent

bindsym Mod4+Shift+minus move scratchpad
bindsym Mod4+minus scratchpad show

bindsym Mod4+c kill
# bindsym Mod4+Shift+c

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym Mod4+1 workspace $ws1
bindsym Mod4+2 workspace $ws2
bindsym Mod4+3 workspace $ws3
bindsym Mod4+4 workspace $ws4
bindsym Mod4+5 workspace $ws5
bindsym Mod4+6 workspace $ws6
bindsym Mod4+7 workspace $ws7
bindsym Mod4+8 workspace $ws8
bindsym Mod4+9 workspace $ws9
bindsym Mod4+0 workspace $ws10

bindsym Mod4+Shift+1 move container to workspace $ws1
bindsym Mod4+Shift+2 move container to workspace $ws2
bindsym Mod4+Shift+3 move container to workspace $ws3
bindsym Mod4+Shift+4 move container to workspace $ws4
bindsym Mod4+Shift+5 move container to workspace $ws5
bindsym Mod4+Shift+6 move container to workspace $ws6
bindsym Mod4+Shift+7 move container to workspace $ws7
bindsym Mod4+Shift+8 move container to workspace $ws8
bindsym Mod4+Shift+9 move container to workspace $ws9
bindsym Mod4+Shift+0 move container to workspace $ws10

bindsym Mod4+comma focus output left
bindsym Mod4+period focus output right
bindsym Mod4+Shift+comma move container to output left
bindsym Mod4+Shift+period move container to output left

bindsym Mod4+Shift+r restart
bindsym Mod4+Mod1+l exit

# Program bindings

bindsym Mod4+Mod1+s systemctl poweroff
bindsym Mod4+Mod1+r systemctl reboot

bindsym Mod4+space exec rofi -show drun -show-icons

bindsym Mod4+Return exec gnome-terminal
bindsym Mod4+w exec firefox-developer-edition
bindsym Mod4+Shift+w exec firefox-developer-edition --private-window

bindsym Mod4+Mod1+c exec clion
bindsym Mod4+Mod1+p exec pycharm
bindsym Mod4+Mod1+j exec intellij
bindsym Mod4+Mod1+g exec goland
bindsym Mod4+Mod1+v exec code

# Startup programs

exec compton
exec xfsettingsd
exec xfce4-notifyd
exec nitrogen --restore
exec dex -a
exec thunar --daemon
exec CM_SELECTIONS="clipboard" clipmenud

# Bar

bar {
        status_command i3status
}
